<!DOCTYPE html>
<html lang="en" class="antialiased">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Universal AI Chat</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#f0f9ff',
                            500: '#0ea5e9',
                            600: '#0284c7',
                        }
                    }
                }
            }
        }
    </script>
    
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <style>
        /* Mobile-safe viewport heights */
        html, body {
            min-height: 100dvh;
            margin: 0;
            padding: 0;
            background-color: #ffffff;
        }
        .dark body { background-color: #111827; }

        /* Loader Animation */
        #loading {
            position: fixed;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #ffffff;
            z-index: 9999;
            font-family: sans-serif;
            font-size: 1.2rem;
            color: #333;
            transition: opacity 0.3s ease;
        }
        .dark #loading {
            background-color: #111827;
            color: #f3f4f6;
        }
        .spinner {
            border: 4px solid rgba(0,0,0,0.1);
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border-left-color: #0ea5e9;
            animation: spin 1s linear infinite;
            margin-right: 12px;
        }
        .dark .spinner { border: 4px solid rgba(255,255,255,0.1); border-left-color: #0ea5e9; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        /* Markdown Styles */
        .markdown-body p { margin-bottom: 0.75rem; }
        .markdown-body p:last-child { margin-bottom: 0; }
        .markdown-body pre { background: #1f2937; color: #f3f4f6; padding: 1rem; border-radius: 0.5rem; overflow-x: auto; margin-bottom: 0.75rem; }
        .markdown-body code { font-family: monospace; background: rgba(128,128,128,0.2); padding: 0.1rem 0.3rem; border-radius: 0.25rem; }
        .markdown-body pre code { background: none; padding: 0; }
        .markdown-body strong { font-weight: 600; }
        .markdown-body ul { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 0.75rem; }
        .markdown-body ol { list-style-type: decimal; padding-left: 1.5rem; margin-bottom: 0.75rem; }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .dark ::-webkit-scrollbar-thumb { background: #4b5563; }
        
        /* Blinking Cursor for Streaming */
        .streaming-cursor::after {
            content: '▋';
            animation: blink 1s step-start infinite;
            color: #0ea5e9;
            margin-left: 2px;
        }
        @keyframes blink { 50% { opacity: 0; } }
    </style>
</head>
<body class="text-gray-800 dark:text-gray-200 transition-colors duration-200">

    <div id="loading">
        <div class="spinner"></div>
        <span>Loading AI Interface...</span>
    </div>

    <div id="app" class="hidden flex flex-col md:flex-row min-h-[100dvh] w-full relative">
        
        <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-30 hidden md:hidden transition-opacity"></div>

        <aside id="sidebar" class="fixed inset-y-0 left-0 z-40 w-72 bg-gray-50 dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 transform -translate-x-full md:relative md:translate-x-0 transition-transform duration-300 ease-in-out flex flex-col">
            <div class="p-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center">
                <button id="btn-new-chat" class="flex-1 bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg p-2.5 flex items-center justify-center gap-2 hover:bg-gray-100 dark:hover:bg-gray-600 transition-colors shadow-sm text-sm font-medium">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    New Chat
                </button>
                <button id="btn-close-sidebar" class="md:hidden ml-2 p-2 text-gray-500 hover:text-gray-800 dark:text-gray-400 dark:hover:text-white">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            
            <div class="flex-1 overflow-y-auto p-3 space-y-2" id="chat-list">
                </div>

            <div class="p-4 border-t border-gray-200 dark:border-gray-700 space-y-2">
                <button id="btn-settings" class="w-full flex items-center gap-3 p-2.5 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors text-sm font-medium">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    Settings
                </button>
            </div>
        </aside>

        <main class="flex-1 flex flex-col min-w-0 bg-white dark:bg-gray-900 h-[100dvh]">
            
            <header class="h-14 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between px-4 shrink-0 bg-white/80 dark:bg-gray-900/80 backdrop-blur-md sticky top-0 z-10">
                <div class="flex items-center gap-3">
                    <button id="btn-open-sidebar" class="md:hidden p-1.5 rounded-md text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-800 dark:text-gray-400 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                    </button>
                    <h1 class="font-semibold text-lg tracking-tight" id="header-title">New Chat</h1>
                </div>
                
                <button id="btn-theme-toggle" class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-gray-500 dark:text-gray-400">
                    <svg id="icon-sun" class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    <svg id="icon-moon" class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
                </button>
            </header>

            <div id="chat-container" class="flex-1 overflow-y-auto p-4 md:p-6 space-y-6 scroll-smooth pb-32">
                <div id="welcome-screen" class="h-full flex flex-col items-center justify-center text-center px-4 max-w-2xl mx-auto opacity-100 transition-opacity duration-300">
                    <div class="w-16 h-16 bg-brand-500 text-white rounded-2xl flex items-center justify-center mb-6 shadow-lg">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </div>
                    <h2 class="text-3xl font-bold mb-2 text-gray-900 dark:text-white">How can I help you today?</h2>
                    <p class="text-gray-500 dark:text-gray-400 mb-8">Ensure your OpenRouter API Key is set in Settings to begin.</p>
                </div>
                </div>

            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-white via-white to-transparent dark:from-gray-900 dark:via-gray-900 pt-6 pb-4 px-4 md:px-8">
                <div class="max-w-3xl mx-auto relative">
                    <form id="chat-form" class="relative flex items-end gap-2 bg-gray-100 dark:bg-gray-800 rounded-3xl p-2 pl-4 border border-gray-200 dark:border-gray-700 shadow-sm focus-within:ring-2 focus-within:ring-brand-500 focus-within:border-brand-500 transition-shadow">
                        <textarea id="chat-input" rows="1" class="w-full bg-transparent resize-none outline-none max-h-32 py-3 text-gray-900 dark:text-white placeholder-gray-500" placeholder="Type a message..."></textarea>
                        <button type="submit" id="btn-send" class="shrink-0 w-10 h-10 rounded-full bg-brand-500 hover:bg-brand-600 text-white flex items-center justify-center transition-colors disabled:opacity-50 disabled:cursor-not-allowed mb-1 mr-1">
                            <svg class="w-5 h-5 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                        </button>
                    </form>
                    <div class="text-center mt-2 text-xs text-gray-400 dark:text-gray-500">
                        AI can make mistakes. Check important info.
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="settings-modal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center px-4 backdrop-blur-sm transition-opacity">
        <div class="bg-white dark:bg-gray-800 rounded-2xl w-full max-w-md overflow-hidden shadow-2xl transform scale-95 transition-transform duration-200" id="settings-card">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center bg-gray-50 dark:bg-gray-800/50">
                <h3 class="font-semibold text-lg text-gray-900 dark:text-white">Settings</h3>
                <button id="btn-close-settings" class="text-gray-500 hover:text-gray-800 dark:hover:text-white">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="p-6 space-y-5">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">OpenRouter API Key</label>
                    <input type="password" id="input-api-key" class="w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none text-gray-900 dark:text-white placeholder-gray-400" placeholder="sk-or-v1-...">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Model Name</label>
                    <input type="text" id="input-model" class="w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none text-gray-900 dark:text-white" value="deepseek/deepseek-r1:free" placeholder="e.g. google/gemini-pro">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">System Prompt (Global)</label>
                    <textarea id="input-system-prompt" rows="3" class="w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none resize-none text-gray-900 dark:text-white text-sm" placeholder="You are a helpful AI assistant..."></textarea>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 flex justify-end">
                <button id="btn-save-settings" class="px-5 py-2 bg-brand-500 hover:bg-brand-600 text-white font-medium rounded-lg transition-colors shadow-sm">Save Preferences</button>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            
            // --- STATE MANAGEMENT ---
            const defaultSettings = {
                apiKey: '',
                model: 'deepseek/deepseek-r1:free',
                systemPrompt: 'You are a helpful, intelligent assistant. Please format your responses using Markdown.',
                darkMode: true // Default to dark mode for Gemini feel
            };

            let state = {
                chats: [],
                activeChatId: null,
                settings: { ...defaultSettings }
            };

            // --- DOM ELEMENTS ---
            const els = {
                app: document.getElementById('app'),
                loading: document.getElementById('loading'),
                sidebar: document.getElementById('sidebar'),
                sidebarOverlay: document.getElementById('sidebar-overlay'),
                chatContainer: document.getElementById('chat-container'),
                chatList: document.getElementById('chat-list'),
                chatForm: document.getElementById('chat-form'),
                chatInput: document.getElementById('chat-input'),
                btnSend: document.getElementById('btn-send'),
                headerTitle: document.getElementById('header-title'),
                welcomeScreen: document.getElementById('welcome-screen'),
                
                // Settings
                settingsModal: document.getElementById('settings-modal'),
                settingsCard: document.getElementById('settings-card'),
                inputApiKey: document.getElementById('input-api-key'),
                inputModel: document.getElementById('input-model'),
                inputSystemPrompt: document.getElementById('input-system-prompt'),
                
                // Buttons
                btnNewChat: document.getElementById('btn-new-chat'),
                btnSettings: document.getElementById('btn-settings'),
                btnCloseSettings: document.getElementById('btn-close-settings'),
                btnSaveSettings: document.getElementById('btn-save-settings'),
                btnOpenSidebar: document.getElementById('btn-open-sidebar'),
                btnCloseSidebar: document.getElementById('btn-close-sidebar'),
                btnThemeToggle: document.getElementById('btn-theme-toggle')
            };

            // --- INITIALIZATION ---
            function init() {
                loadState();
                applyTheme();
                renderChatList();
                if (state.chats.length === 0) {
                    createNewChat();
                } else {
                    if (!state.activeChatId) state.activeChatId = state.chats[0].id;
                    renderMessages();
                }
                
                setupEventListeners();
                
                // Remove loader, show app
                els.loading.style.opacity = '0';
                setTimeout(() => {
                    els.loading.style.display = 'none';
                    els.app.classList.remove('hidden');
                }, 300);
            }

            function loadState() {
                try {
                    const saved = localStorage.getItem('universal-ai-chat-state');
                    if (saved) {
                        const parsed = JSON.parse(saved);
                        state.chats = parsed.chats || [];
                        state.activeChatId = parsed.activeChatId || null;
                        state.settings = { ...defaultSettings, ...(parsed.settings || {}) };
                    }
                } catch (e) {
                    console.error("Failed to load state", e);
                }
            }

            function saveState() {
                try {
                    localStorage.setItem('universal-ai-chat-state', JSON.stringify(state));
                } catch (e) {
                    console.error("Failed to save state", e);
                }
            }

            // --- THEME ---
            function applyTheme() {
                if (state.settings.darkMode) {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }
            }

            function toggleTheme() {
                state.settings.darkMode = !state.settings.darkMode;
                applyTheme();
                saveState();
            }

            // --- SIDEBAR & MODALS ---
            function openSidebar() {
                els.sidebar.classList.remove('-translate-x-full');
                els.sidebarOverlay.classList.remove('hidden');
            }

            function closeSidebar() {
                els.sidebar.classList.add('-translate-x-full');
                els.sidebarOverlay.classList.add('hidden');
            }

            function openSettings() {
                els.inputApiKey.value = state.settings.apiKey;
                els.inputModel.value = state.settings.model;
                els.inputSystemPrompt.value = state.settings.systemPrompt;
                els.settingsModal.classList.remove('hidden');
                setTimeout(() => { els.settingsCard.classList.remove('scale-95'); }, 10);
            }

            function closeSettings() {
                els.settingsCard.classList.add('scale-95');
                setTimeout(() => { els.settingsModal.classList.add('hidden'); }, 200);
            }

            function saveSettings() {
                state.settings.apiKey = els.inputApiKey.value.trim();
                state.settings.model = els.inputModel.value.trim() || 'deepseek/deepseek-r1:free';
                state.settings.systemPrompt = els.inputSystemPrompt.value.trim();
                saveState();
                closeSettings();
            }

            // --- CHAT MANAGEMENT ---
            function generateId() {
                return Date.now().toString(36) + Math.random().toString(36).substring(2);
            }

            function getActiveChat() {
                return state.chats.find(c => c.id === state.activeChatId);
            }

            function createNewChat() {
                const newChat = {
                    id: generateId(),
                    title: 'New Chat',
                    messages: []
                };
                state.chats.unshift(newChat);
                state.activeChatId = newChat.id;
                saveState();
                renderChatList();
                renderMessages();
                if(window.innerWidth < 768) closeSidebar();
            }

            function deleteChat(id, e) {
                e.stopPropagation();
                if (!confirm("Are you sure you want to delete this chat?")) return;
                
                state.chats = state.chats.filter(c => c.id !== id);
                if (state.activeChatId === id) {
                    state.activeChatId = state.chats.length > 0 ? state.chats[0].id : null;
                }
                if (state.chats.length === 0) createNewChat();
                else {
                    saveState();
                    renderChatList();
                    renderMessages();
                }
            }

            function renameChat(id, e) {
                e.stopPropagation();
                const chat = state.chats.find(c => c.id === id);
                if (!chat) return;
                const newTitle = prompt("Enter new chat name:", chat.title);
                if (newTitle !== null && newTitle.trim() !== "") {
                    chat.title = newTitle.trim();
                    saveState();
                    renderChatList();
                    if(state.activeChatId === id) els.headerTitle.textContent = chat.title;
                }
            }

            function selectChat(id) {
                if (state.activeChatId === id) return;
                state.activeChatId = id;
                saveState();
                renderChatList();
                renderMessages();
                if(window.innerWidth < 768) closeSidebar();
            }

            // --- RENDERING ---
            function renderChatList() {
                els.chatList.innerHTML = '';
                state.chats.forEach(chat => {
                    const isActive = chat.id === state.activeChatId;
                    const btn = document.createElement('div');
                    btn.className = `group flex items-center justify-between p-2.5 rounded-lg cursor-pointer transition-colors ${isActive ? 'bg-gray-200 dark:bg-gray-700 text-gray-900 dark:text-white' : 'hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-600 dark:text-gray-300'}`;
                    btn.onclick = () => selectChat(chat.id);
                    
                    const titleDiv = document.createElement('div');
                    titleDiv.className = 'flex items-center gap-3 overflow-hidden';
                    titleDiv.innerHTML = `
                        <svg class="w-4 h-4 shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
                        <span class="truncate text-sm font-medium">${escapeHtml(chat.title)}</span>
                    `;

                    const actionsDiv = document.createElement('div');
                    actionsDiv.className = `flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity ${isActive ? 'opacity-100' : ''}`;
                    
                    const btnRename = document.createElement('button');
                    btnRename.innerHTML = `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>`;
                    btnRename.className = 'p-1.5 text-gray-400 hover:text-gray-800 dark:hover:text-white rounded';
                    btnRename.onclick = (e) => renameChat(chat.id, e);

                    const btnDelete = document.createElement('button');
                    btnDelete.innerHTML = `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>`;
                    btnDelete.className = 'p-1.5 text-gray-400 hover:text-red-500 rounded';
                    btnDelete.onclick = (e) => deleteChat(chat.id, e);

                    actionsDiv.appendChild(btnRename);
                    actionsDiv.appendChild(btnDelete);

                    btn.appendChild(titleDiv);
                    btn.appendChild(actionsDiv);
                    els.chatList.appendChild(btn);
                });
            }

            function renderMessages() {
                const chat = getActiveChat();
                if (!chat) return;

                els.headerTitle.textContent = chat.title;
                
                // Keep welcome screen if empty
                if (chat.messages.length === 0) {
                    els.welcomeScreen.style.display = 'flex';
                    // Remove all message elements
                    Array.from(els.chatContainer.children).forEach(child => {
                        if (child.id !== 'welcome-screen') child.remove();
                    });
                    return;
                }

                els.welcomeScreen.style.display = 'none';
                
                // Clear existing messages
                Array.from(els.chatContainer.children).forEach(child => {
                    if (child.id !== 'welcome-screen') child.remove();
                });

                chat.messages.forEach(msg => {
                    appendMessageElement(msg.role, msg.content, msg.id);
                });

                scrollToBottom();
            }

            function appendMessageElement(role, content, id) {
                const wrapper = document.createElement('div');
                wrapper.className = `flex w-full ${role === 'user' ? 'justify-end' : 'justify-start'}`;
                wrapper.id = `msg-${id}`;

                const inner = document.createElement('div');
                
                if (role === 'user') {
                    inner.className = 'max-w-[85%] md:max-w-[70%] bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-gray-100 rounded-3xl rounded-tr-sm px-5 py-3 shadow-sm';
                    inner.textContent = content; // User text is raw
                } else {
                    inner.className = 'max-w-[100%] md:max-w-[85%] text-gray-800 dark:text-gray-200 markdown-body w-full';
                    
                    // Add AI Avatar wrapper
                    const aiWrapper = document.createElement('div');
                    aiWrapper.className = 'flex gap-4';
                    
                    const avatar = document.createElement('div');
                    avatar.className = 'w-8 h-8 shrink-0 rounded-full bg-brand-500 flex items-center justify-center text-white mt-1 shadow-sm';
                    avatar.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>`;
                    
                    const contentDiv = document.createElement('div');
                    contentDiv.className = 'flex-1 overflow-x-hidden pt-1';
                    contentDiv.innerHTML = marked.parse(content || '');
                    
                    aiWrapper.appendChild(avatar);
                    aiWrapper.appendChild(contentDiv);
                    inner.appendChild(aiWrapper);
                }

                wrapper.appendChild(inner);
                els.chatContainer.appendChild(wrapper);
                scrollToBottom();
                return wrapper;
            }

            function updateAiMessageElement(id, newContent, isStreaming = false) {
                const el = document.getElementById(`msg-${id}`);
                if (!el) return;
                const contentDiv = el.querySelector('.flex-1');
                if (contentDiv) {
                    contentDiv.innerHTML = marked.parse(newContent);
                    if (isStreaming) {
                        contentDiv.classList.add('streaming-cursor');
                    } else {
                        contentDiv.classList.remove('streaming-cursor');
                    }
                }
                scrollToBottom();
            }

            // --- API / CHAT LOGIC ---
            async function handleSend(e) {
                e.preventDefault();
                const text = els.chatInput.value.trim();
                if (!text) return;

                if (!state.settings.apiKey) {
                    alert('Please set your OpenRouter API Key in Settings first.');
                    openSettings();
                    return;
                }

                const chat = getActiveChat();
                if (!chat) return;

                // Auto-generate title for first message
                if (chat.messages.length === 0) {
                    chat.title = text.length > 25 ? text.substring(0, 25) + '...' : text;
                    renderChatList();
                }

                // Add User Message
                els.chatInput.value = '';
                els.chatInput.style.height = 'auto';
                els.btnSend.disabled = true;
                els.welcomeScreen.style.display = 'none';

                const userMsg = { id: generateId(), role: 'user', content: text };
                chat.messages.push(userMsg);
                appendMessageElement('user', text, userMsg.id);

                // Add Empty AI Message Stub
                const aiMsgId = generateId();
                const aiMsg = { id: aiMsgId, role: 'assistant', content: '' };
                chat.messages.push(aiMsg);
                appendMessageElement('assistant', '', aiMsgId);
                updateAiMessageElement(aiMsgId, '', true);

                saveState();

                // Prepare API request
                const apiMessages = [];
                if (state.settings.systemPrompt) {
                    apiMessages.push({ role: 'system', content: state.settings.systemPrompt });
                }
                // Only send last 10 messages for context to save tokens, excluding the empty one just added
                const contextMessages = chat.messages.slice(-11, -1).map(m => ({ role: m.role, content: m.content }));
                apiMessages.push(...contextMessages);

                try {
                    const response = await fetch('https://openrouter.ai/api/v1/chat/completions', {
                        method: 'POST',
                        headers: {
                            'Authorization': `Bearer ${state.settings.apiKey}`,
                            'Content-Type': 'application/json',
                            'HTTP-Referer': window.location.href, // OpenRouter requirement
                            'X-Title': 'Universal AI Chat' // OpenRouter requirement
                        },
                        body: JSON.stringify({
                            model: state.settings.model,
                            messages: apiMessages,
                            stream: true
                        })
                    });

                    if (!response.ok) {
                        const err = await response.text();
                        throw new Error(`API Error: ${response.status} - ${err}`);
                    }

                    // Handle Streaming Response
                    const reader = response.body.getReader();
                    const decoder = new TextDecoder('utf-8');
                    let done = false;
                    let fullContent = '';

                    while (!done) {
                        const { value, done: readerDone } = await reader.read();
                        done = readerDone;
                        if (value) {
                            const chunk = decoder.decode(value, { stream: true });
                            const lines = chunk.split('\n').filter(line => line.trim() !== '');
                            
                            for (const line of lines) {
                                if (line.startsWith('data: ')) {
                                    const dataStr = line.replace('data: ', '').trim();
                                    if (dataStr === '[DONE]') continue;
                                    try {
                                        const data = JSON.parse(dataStr);
                                        const contentChunk = data.choices[0]?.delta?.content || '';
                                        fullContent += contentChunk;
                                        // Throttle DOM updates slightly by relying on the loop speed,
                                        // markdown parsing is fast enough for standard streams.
                                        updateAiMessageElement(aiMsgId, fullContent, true);
                                    } catch (e) {
                                        console.warn("Error parsing chunk", e, dataStr);
                                    }
                                }
                            }
                        }
                    }

                    // Finalize
                    aiMsg.content = fullContent;
                    updateAiMessageElement(aiMsgId, fullContent, false);
                    saveState();

                } catch (error) {
                    console.error('Chat error:', error);
                    aiMsg.content = `**Error:** ${error.message}`;
                    updateAiMessageElement(aiMsgId, aiMsg.content, false);
                    saveState();
                } finally {
                    els.btnSend.disabled = false;
                    els.chatInput.focus();
                }
            }

            // --- UTILS & LISTENERS ---
            function escapeHtml(unsafe) {
                return (unsafe || '').toString()
                     .replace(/&/g, "&amp;")
                     .replace(/</g, "&lt;")
                     .replace(/>/g, "&gt;")
                     .replace(/"/g, "&quot;")
                     .replace(/'/g, "&#039;");
            }

            function scrollToBottom() {
                setTimeout(() => {
                    els.chatContainer.scrollTop = els.chatContainer.scrollHeight;
                }, 50);
            }

            function handleInputAutosize() {
                els.chatInput.style.height = 'auto';
                els.chatInput.style.height = (els.chatInput.scrollHeight) + 'px';
                if (els.chatInput.value.trim() === '') {
                    els.chatInput.style.height = 'auto'; // Reset when empty
                }
            }

            function setupEventListeners() {
                // Sidebar
                els.btnOpenSidebar.addEventListener('click', openSidebar);
                els.btnCloseSidebar.addEventListener('click', closeSidebar);
                els.sidebarOverlay.addEventListener('click', closeSidebar);
                els.btnNewChat.addEventListener('click', createNewChat);

                // Settings
                els.btnSettings.addEventListener('click', openSettings);
                els.btnCloseSettings.addEventListener('click', closeSettings);
                els.btnSaveSettings.addEventListener('click', saveSettings);
                
                // Theme
                els.btnThemeToggle.addEventListener('click', toggleTheme);

                // Chat Input
                els.chatInput.addEventListener('input', handleInputAutosize);
                els.chatInput.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter' && !e.shiftKey) {
                        e.preventDefault();
                        handleSend(e);
                    }
                });
                els.chatForm.addEventListener('submit', handleSend);

                // Configure marked.js to be secure-ish and avoid deprecation warnings
                marked.setOptions({
                    breaks: true,
                    gfm: true
                });
            }

            // Start the app
            init();
        });
    </script>
</body>
</html>
